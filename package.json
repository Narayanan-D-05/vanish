    "@langchain/openai": "^1.2.12",
    "@zk-kit/incremental-merkle-tree": "^1.1.0",
    "axios": "^1.13.6",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "fs-extra": "^11.3.4",
    "hedera-agent-kit": "^3.8.0",
    "js-sha3": "^0.9.3",
    "langchain": "^1.2.30",
    "ollama": "^0.6.3",
