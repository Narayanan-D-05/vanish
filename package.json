{
  "name": "vanish",
  "version": "1.0.0",
  "description": "Double-Blind AI Privacy Layer for Hedera - A Confidential AI Agent that shields wallet balances and transaction history",
  "main": "index.js",
  "scripts": {
    "create:account": "node create-new-account.cjs",
    "setup:topics": "node setup-topics.cjs",
    "compile": "hardhat compile",
    "compile:circuits": "node build-circuits.cjs",
    "deploy:contract": "hardhat run scripts/deploy.js",
    "associate:tokens": "node associate-tokens.cjs",
    "verify:production": "node verify-production.cjs",
    "start:pool": "node agents/pool-manager/index.cjs",
    "start:user": "node agents/user-agent/index.cjs",
    "start:user:ai": "node agents/user-agent/ai-mode.cjs",
    "start:receiver": "node agents/receiver-agent/index.cjs",
    "start:receiver:demo": "node agents/receiver-agent/index.cjs",
    "start:all": "npx concurrently -n \"POOL,RCVR,USER\" -c \"magenta,blue,green\" \"npm run start:pool\" \"npm run start:receiver\" \"npm run start:user\"",
    "demo": "node demo-run.cjs",
    "test:agents": "node test-agents.cjs",
    "test:fragmentation": "node test-fragmentation.cjs",
    "test:ai": "node test-ai-vs-rules.cjs",
    "test:performance": "node test-performance.cjs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "hedera",
    "privacy",
    "ai-agents",
    "zk-snarks",
    "stealth-addresses",
    "blockchain",
    "HIP-1340",
    "HTS",
    "HCS"
